# Horsera Pose API — environment variables
# Copy this file to .env for local development (never commit .env)

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (Settings → API → Project URL)
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Publishable / anon key (Settings → API → Project API keys → anon public)
SUPABASE_KEY=sb_publishable_...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (defaults shown)
# CORS_ORIGINS=https://horsera.app,http://localhost:5173

# ── GCP upload flow ───────────────────────────────────────────────────────────
# Bucket used for direct signed-url uploads and worker reads
GCS_UPLOAD_BUCKET=horsera-pose-input

# Prefix/folder inside the bucket for incoming uploads
GCS_UPLOAD_PREFIX=uploads

# Optional signer identity for V4 signed URLs (usually set in Cloud Run)
# GCS_SIGNING_SERVICE_ACCOUNT_EMAIL=horseraposeapi@your-gcp-project-id.iam.gserviceaccount.com

# Signed URL validity window (seconds)
SIGNED_URL_TTL_SECONDS=900

# ── Job state backend ─────────────────────────────────────────────────────────
# memory | firestore
JOB_STORE_BACKEND=memory

# Firestore collection for job state when JOB_STORE_BACKEND=firestore
FIRESTORE_COLLECTION=pose_jobs

# ── Execution backend ─────────────────────────────────────────────────────────
# inline | cloud_run_job
EXECUTION_BACKEND=inline

# Choose GPU worker when size_mb >= threshold
GPU_THRESHOLD_MB=120

# Required when EXECUTION_BACKEND=cloud_run_job
# CLOUD_RUN_PROJECT=your-gcp-project-id
# CLOUD_RUN_REGION=us-east4
# CLOUD_RUN_CPU_JOB=pose-worker-cpu
# CLOUD_RUN_GPU_JOB=pose-worker-gpu

# ── Phase 2 hybrid model (optional) ───────────────────────────────────────────
# Set to 1 to enable MediaPipe + YOLOv8 ensemble (see pipeline.py stub)
# HORSERA_PHASE2=0
